{
  "color": {
    "surface": { "default": "#0f0f11", "raised": "#16161a", "hover": "#1c1c21", "card": "#131316" },
    "border": { "default": "#252529", "subtle": "#1e1e22" },
    "text": { "primary": "#f2f0eb", "secondary": "#a8a29e", "muted": "#78716c" },
    "accent": { "default": "#9070d4", "dim": "#352a52", "hover": "#a280e0", "bright": "#b090e8" },
    "status": { "safe": "#22c55e", "caution": "#eab308", "blocklist": "#ef4444" }
  },
  "font": {
    "serif": "'Cormorant Garamond', Georgia, serif",
    "sans": "'Inter', system-ui, sans-serif",
    "mono": "'JetBrains Mono', monospace"
  },
  "spacing": {
    "section": { "hero": "4rem 3rem 3rem", "content": "2.5rem 3rem" },
    "card": "1.5rem",
    "gap": { "min": "0.5rem", "card": "1rem", "section": "1.5rem" }
  },
  "radius": { "sm": "4px", "md": "8px", "lg": "12px", "xl": "14px", "pill": "9999px" },
  "animation": {
    "fast": "150ms", "normal": "300ms", "slow": "500ms",
    "easing": "cubic-bezier(0.16, 1, 0.3, 1)",
    "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
  },
  "breakpoints": { "mobile": "768px", "min": "320px" },
  "sidebar": { "width": "220px" }
}
